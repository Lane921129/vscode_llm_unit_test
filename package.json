{
  "name": "llm-unit-test",
  "displayName": "llm_unit_test",
  "description": "Using llm to generate unit test and analyzation for user",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "license": "MIT",
  "categories": [
    "Testing"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mutation-test-explorer",
          "title": "突變測試分析",
          "icon": "$(beaker)"
        }
      ]
    },
    "views": {
      "mutation-test-explorer": [
        {
          "type": "webview",
          "id": "mutation-test-view",
          "name": "模型與測試設定"
        }
      ]
    },
    "commands": [
      {
        "command": "llm-unit-test.runCaptureAndTest",
        "title": "執行自動化測試循環"
      }
    ],
    "configuration": {
      "title": "LLM 自動化測試設定",
      "properties": {
        "llmUnitTest.modelName": {
          "type": "string",
          "default": "phi4-mini-reasoning",
          "description": "請輸入本地 Ollama 模型名稱 (例如: phi4-mini-reasoning, llama3)"
        },
        "llmUnitTest.apiKeys": {
          "type": "object",
          "default": {},
          "description": "請輸入雲端 LLM 的 API Key (例如 Gemini 或 OpenAI)"
        },
        "llmUnitTest.projectPath": {
          "type": "string",
          "default": "",
          "description": "測試專案資料夾路徑"
        },
        "llmUnitTest.outputPath": {
          "type": "string",
          "default": "",
          "description": "測試結果輸出資料夾路徑"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
